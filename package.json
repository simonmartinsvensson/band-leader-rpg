{
  "name": "band-leader-rpg",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:host": "vite --host",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "gen:assets": "node scripts/gen-placeholders.mjs",
    "gen:map": "node scripts/gen-map.mjs",
    "gen:font": "node scripts/gen-font.mjs",
    "gen:audio": "node scripts/gen-audio.mjs",
    "gen:characters": "python3 scripts/repack-characters.py",
    "test": "vitest run",
    "check:data": "vitest run tests/datamodel.test.ts --disable-console-intercept",
    "smoke": "node scripts/smoke.mjs"
  },
  "devDependencies": {
    "playwright": "^1.60.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  }
}
